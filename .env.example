# -------- Supabase (Settings → API) --------
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# -------- Formularze kontaktowe (Resend) --------
# Klucze dla /api/send-contact (Vercel Edge Function). Wszystkie
# formularze na stronie (Kontakt, Cennik, Konsultacja, Newsletter,
# Kalkulator, Generator Briefu, Chatbot, Footer) przechodzą przez
# ten endpoint. Ustaw w:
#   Vercel → Project → Settings → Environment Variables
#
# Wymagane:
RESEND_API_KEY=""
#
# Opcjonalne (jeśli puste, używane są wartości domyślne):
#   CONTACT_INBOX  — adres odbiorczy (domyślnie a.mazziarz@gmail.com)
#   CONTACT_FROM   — pole "From" (domyślnie onboarding@resend.dev)
CONTACT_INBOX=""
CONTACT_FROM=""

# -------- (opcjonalnie) dev/preview --------
# Jeśli chcesz, żeby lokalne `vite dev` uderzało w zdalny endpoint
# (np. deploy preview), ustaw pełny URL. W produkcji zostaw pusty.
VITE_CONTACT_ENDPOINT=""
